generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkId      String    @unique
  email        String
  profileImage String
  firstName    String?
  lastName     String?
  username     String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  galleries    Gallery[]
}

model Gallery {
  id          String                     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  price       String
  images      String[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  user        User                       @relation(fields: [userId], references: [clerkId])
  userId      String
  categories  GalleryCategoryOnGallery[]
}

model GalleryCategory {
  id        String                     @id @default(auto()) @map("_id") @db.ObjectId
  name      String                     @unique
  galleries GalleryCategoryOnGallery[]
}

// Junction Table (ตารางกลาง)
model GalleryCategoryOnGallery {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  gallery    Gallery         @relation(fields: [galleryId], references: [id])
  galleryId  String          @db.ObjectId
  category   GalleryCategory @relation(fields: [categoryId], references: [id])
  categoryId String          @db.ObjectId
}
